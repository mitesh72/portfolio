# Optional: enables the contact form to actually send you an email.
# Get a free API key at https://resend.com (no credit card needed for the free tier).
RESEND_API_KEY=

# Where contact form messages should be sent. Defaults to your resume email if unset.
CONTACT_TO_EMAIL=uniyalmitesh812@gmail.com

# Sender shown in the email "from" field. Until you verify your own domain with
# Resend, leave this as the default — Resend's shared domain works out of the box.
CONTACT_FROM_EMAIL=Portfolio Contact Form <onboarding@resend.dev>
